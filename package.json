{
  "name": "@lickle/trace",
  "version": "0.0.1-alpha.8",
  "description": "A minimal, structured tracing utility for TypeScript/JavaScript, inspired by Rust's tracing crate. It provides spans, events, and a higher-level logging abstraction.",
  "author": "Dan Beaven <dm.beaven@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pingid/lickle-trace.git"
  },
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.js",
  "sideEffects": false,
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./log": {
      "types": "./dist/log.d.ts",
      "import": "./dist/log.js"
    },
    "./layer": {
      "types": "./dist/layer/index.d.ts",
      "import": "./dist/layer/index.js"
    }
  },
  "imports": {
    "#registry": {
      "browser": {
        "types": "./dist/registry/universal.d.ts",
        "default": "./dist/registry/universal.js"
      },
      "node": {
        "types": "./dist/registry/node.d.ts",
        "default": "./dist/registry/node.js"
      },
      "default": {
        "types": "./dist/registry/universal.d.ts",
        "default": "./dist/registry/universal.js"
      }
    },
    "#layer/util": {
      "browser": {
        "types": "./dist/layer/util/browser.d.ts",
        "default": "./dist/layer/util/browser.js"
      },
      "node": {
        "types": "./dist/layer/util/node.d.ts",
        "default": "./dist/layer/util/node.js"
      },
      "default": {
        "types": "./dist/layer/util/universal.d.ts",
        "default": "./dist/layer/util/universal.js"
      }
    }
  },
  "files": [
    "dist",
    "src",
    "!**/*.test.*"
  ],
  "keywords": [
    "logging",
    "logger",
    "tracing",
    "spans",
    "structured-logging",
    "debug"
  ],
  "scripts": {
    "build": "tsc",
    "docs:build": "ldocs build",
    "docs:dev": "ldocs dev",
    "format": "prettier --write .",
    "test": "vitest"
  },
  "devDependencies": {
    "@lickle/docs": "0.0.2-dev.2",
    "@types/node": "^26.1.1",
    "jsr": "^0.14.3",
    "prettier": "^3.9.4",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "printWidth": 120,
    "trailingComma": "all"
  }
}
