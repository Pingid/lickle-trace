{
  "name": "@lickle/trace",
  "version": "0.0.1-alpha.5",
  "description": "A minimal, structured tracing utility for TypeScript/JavaScript, inspired by Rust's tracing crate. It provides spans, events, and a higher-level logging abstraction.",
  "author": "Dan Beaven <dm.beaven@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pingid/lickle-trace.git"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "lib/cjs/index.js",
  "types": "lib/ts/index.d.ts",
  "module": "lib/esm/index.js",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./lib/ts/index.d.ts",
      "browser": {
        "import": "./lib/esm/browser.js",
        "require": "./lib/cjs/browser.js"
      },
      "node": {
        "import": "./lib/esm/node.js",
        "require": "./lib/cjs/node.js"
      },
      "default": {
        "import": "./lib/esm/index.js",
        "require": "./lib/cjs/index.js"
      }
    },
    "./node": {
      "import": "./lib/esm/node.js",
      "require": "./lib/cjs/node.js",
      "types": "./lib/ts/node.d.ts"
    },
    "./browser": {
      "import": "./lib/esm/browser.js",
      "require": "./lib/cjs/browser.js",
      "types": "./lib/ts/browser.d.ts"
    },
    "./trace": {
      "import": "./lib/esm/trace.js",
      "require": "./lib/cjs/trace.js",
      "types": "./lib/ts/trace.d.ts"
    }
  },
  "browser": {
    "./lib/cjs/index.js": "./lib/cjs/browser.js",
    "./lib/esm/index.js": "./lib/esm/browser.js"
  },
  "files": [
    "lib",
    "README.md"
  ],
  "keywords": [
    "tracing",
    "logging",
    "logger",
    "debug"
  ],
  "scripts": {
    "build": "npm run esm && npm run cjs",
    "format": "prettier --write .",
    "esm": "tsc -p ./tsconfig.esm.json",
    "cjs": "tsc -p ./tsconfig.cjs.json",
    "test": "vitest"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "jsdom": "^27.0.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "printWidth": 120,
    "trailingComma": "all"
  }
}
